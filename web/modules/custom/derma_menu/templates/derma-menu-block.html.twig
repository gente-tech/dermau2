<nav class="du-header__nav">
	<ul class="du-header__nav-list" id="duNavList">

		<div class="du-header__nav-close" id="duMenuClose">
			<svg width="23" height="23" viewbox="0 0 23 23" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M11.5 1.4375C5.89375 1.4375 1.4375 5.89375 1.4375 11.5C1.4375 17.1062 5.89375 21.5625 11.5 21.5625C17.1062 21.5625 21.5625 17.1062 21.5625 11.5C21.5625 5.89375 17.1062 1.4375 11.5 1.4375ZM11.5 20.125C6.75625 20.125 2.875 16.2437 2.875 11.5C2.875 6.75625 6.75625 2.875 11.5 2.875C16.2437 2.875 20.125 6.75625 20.125 11.5C20.125 16.2437 16.2437 20.125 11.5 20.125Z" fill="#1C224A"/>
				<path d="M15.3812 16.5312L11.5 12.65L7.61875 16.5312L6.46875 15.3812L10.35 11.5L6.46875 7.61875L7.61875 6.46875L11.5 10.35L15.3812 6.46875L16.5312 7.61875L12.65 11.5L16.5312 15.3812L15.3812 16.5312Z" fill="#1C224A"/>
			</svg>
		</div>

		{% for element in items %}
			{% set url = element.link.getUrlObject() %}
			{% set title = element.link.getTitle() %}

			<li class="du-header__nav-item">
				<a href="{{ url.toString() }}" class="du-header__nav-link {{ element.in_active_trail ? 'du-header__nav-link--active' }}">
					{{ title }}
					{% if element.subtree %}
						<span class="du-icon__down"></span>
					{% endif %}
				</a>

				{% if element.subtree %}
					<ul class="du-header__nav-dropdown">
						{% for child in element.subtree %}
							{% set child_url = child.link.getUrlObject() %}
							{% set child_title = child.link.getTitle() %}

							<li>
								<a href="{{ child_url.toString() }}" class="du-header__nav-dropdown-link {{ child.in_active_trail ? 'du-header__nav-dropdown-link--active' }}">
									{{ child_title }}
								</a>
							</li>
						{% endfor %}
					</ul>
				{% endif %}
			</li>
		{% endfor %}

		<li class="du-header__nav-item">
			<a target="_blank" href="https://campus.dermau.net/d2l/login" class="du-btn-campus">
				Ingresar al campus
				<span class="du-icon__next"></span>
			</a>
		</li>

	</ul>
</nav>
