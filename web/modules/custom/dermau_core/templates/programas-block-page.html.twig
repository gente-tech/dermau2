<section class="du-seach">
  <div class="du-seach__container">
    <div class="du-seach__content">

      <div class="du-seach__input">
        <input type="text" id="program-search" placeholder="Buscar programa..." />
      </div>

      <div class="du-seach__filters">

        <div class="du-filter-down">
          <div class="du-filter-down__header">
            <div class="du-filter-down__icon">
              <svg width="18" height="17" viewBox="0 0 18 17" fill="none">
                <path d="M1.625 0.75H15.625C15.8571 0.75 16.0796 0.842187 16.2437 1.00628C16.4078 1.17038 16.5 1.39294 16.5 1.625V3.01275C16.5 3.2448 16.4077 3.46732 16.2436 3.63137L10.6314 9.24362C10.4673 9.40768 10.375 9.6302 10.375 9.86225V15.3791" stroke="#007BE3"/>
              </svg>
            </div>
            <div class="du-filter-down__title" id="filter-universidad" data-value="0">
              Todas las universidades
            </div>
          </div>

          <ul class="du-filter-down__options" data-rel="filter-universidad">
            <li data-value="0">Todas las universidades</li>
          </ul>
        </div>


        <div class="du-filter-down">
          <div class="du-filter-down__header">
            <div class="du-filter-down__icon">
              <svg width="21" height="17" viewBox="0 0 21 17" fill="none">
                <path d="M0 0.65625C0 0.482202 0.0691404 0.315282 0.192211 0.192211C0.315282 0.0691405 0.482202 0 0.65625 0H7.21612" fill="#007BE3"/>
              </svg>
            </div>
            <div class="du-filter-down__title" id="filter-programa" data-value="0">
              Todos los programas
            </div>
          </div>

          <ul class="du-filter-down__options" data-rel="filter-programa">
            <li data-value="0">Todos los programas</li>

            {% for programa in programas %}
              <li data-value="{{ programa.id }}">
                {{ programa.tipo }}
              </li>
            {% endfor %}

          </ul>
        </div>

      </div>
    </div>
  </div>
</section>


<section class="du-generic-swiper du-swiper-program">

  <div class="du-generic-swiper__container du-swiper-oferta__container">

    <div class="du-generic-swiper__header">
      <h3>
        Mostrando <span>{{ programas|length }} programas</span>
      </h3>
    </div>


    <div class="swiper">
      <div class="swiper-wrapper" id="card__diplomat">

       {% for programa in programas %}

<div class="swiper-slide">


<article class="du-card__diplomat">
  <div class="du-card__diplomat-image-container">
    <span class="du-card__diplomat-badge">{{ programa.tipo }}</span>

    <img
      src="{{ programa.imagen }}"
      alt="{{ programa.titulo }}"
      class="du-card__diplomat-image"
    >
  </div>

  <div class="du-card__diplomat-content">

    <h3 class="du-card__diplomat-title">
      {{ programa.titulo }}
    </h3>

    <p class="du-card__diplomat-description">
      {{ programa.descripcion }}
    </p>

    <div class="du-card__diplomat-info">

      <div class="du-card__diplomat-info-item">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7.22917 13.9583C10.9456 13.9583 13.9583 10.9456 13.9583 7.22917C13.9583 3.51275 10.9456 0.5 7.22917 0.5C3.51275 0.5 0.5 3.51275 0.5 7.22917C0.5 10.9456 3.51275 13.9583 7.22917 13.9583Z" stroke="#007BE3"></path>
          <path d="M10.7916 7.22921H7.42704C7.37455 7.22921 7.32421 7.20836 7.28709 7.17124C7.24998 7.13412 7.22913 7.08378 7.22913 7.03129V4.45837" stroke="#007BE3" stroke-linecap="round"></path>
        </svg>
        {{ programa.duracion }}
      </div>

      <div class="du-card__diplomat-info-item">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 0.625C0 0.45924 0.065848 0.300269 0.183058 0.183058C0.300268 0.0658481 0.45924 9.75268e-08 0.625 9.75268e-08H6.8725C8.1775 9.75268e-08 9.32667 0.666667 9.99833 1.67833C10.3404 1.16218 10.805 0.738778 11.3506 0.445918C11.8962 0.153058 12.5058 -0.000141109 13.125 9.75268e-08H19.375C19.5408 9.75268e-08 19.6997 0.0658481 19.8169 0.183058C19.9342 0.300269 20 0.45924 20 0.625V13.1775C20 13.2599 19.9837 13.3415 19.952 13.4176C19.9204 13.4937 19.8739 13.5628 19.8155 13.6209C19.757 13.679 19.6876 13.725 19.6113 13.7561C19.535 13.7873 19.4533 13.8031 19.3708 13.8025L12.9692 13.7592C12.638 13.7568 12.3097 13.8203 12.0033 13.9459C11.6968 14.0715 11.4184 14.2567 11.1842 14.4908L10.4425 15.2333C10.3845 15.2914 10.3155 15.3375 10.2397 15.3689C10.1638 15.4004 10.0825 15.4165 10.0004 15.4165C9.91831 15.4165 9.837 15.4004 9.76115 15.3689C9.68529 15.3375 9.61637 15.2914 9.55833 15.2333L8.80667 14.4825C8.33793 14.0136 7.70215 13.7501 7.03917 13.75H0.625C0.45924 13.75 0.300268 13.6842 0.183058 13.5669C0.065848 13.4497 0 13.2908 0 13.125L0 0.625Z" fill="#007BE3"></path>
        </svg>
        {{ programa.modulos }} módulos
      </div>

      <div class="du-card__diplomat-info-item">
        <svg width="16" height="14" viewBox="0 0 16 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10.6111 13.5V12.0555C10.6111 11.2893 10.3067 10.5545 9.76497 10.0128C9.2232 9.47099 8.4884 9.16663 7.72222 9.16663H3.38889C2.62271 9.16663 1.88791 9.47099 1.34614 10.0128C0.804364 10.5545 0.5 11.2893 0.5 12.0555V13.5" stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span class="du-card__diplomat-info-text">Cupos limitados</span>
      </div>

    </div>

    <a href="{{ programa.url }}" class="du-card__diplomat-btn">
      Ver detalle
    </a>

  </div>
</article>

</div>

{% endfor %} 

      </div>


      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>

    </div>

  </div>

</section>
