<section class="du-agreements" id="convenios-universitarios">
  <div class="du-agreements__container">

    <div class="du-agreements__header">
      <h2 class="du-agreements__title">
        <span>{{ titulo_parte_1 }}</span> {{ titulo_parte_2 }}
      </h2>

      {% if descripcion %}
        <p class="du-agreements__subtitle">
          {{ descripcion }}
        </p>
      {% endif %}
    </div>

    <div class="swiper swiper-container">
      <div class="swiper-wrapper">

        {% for logo in items %}
          <div class="swiper-slide du-agreements__slide">
            <img src="{{ logo }}" alt="Convenio" loading="lazy">
          </div>
        {% endfor %}

      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>
    </div>

  </div>
</section>
