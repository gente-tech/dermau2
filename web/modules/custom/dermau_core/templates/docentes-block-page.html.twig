<section class="du-seach">
  <div class="du-seach__container">
    <div class="du-seach__content">
      <div class="du-seach__input">
        <input type="text" id="buscar-docente" placeholder="Buscar docente...">
      </div>
      <div class="du-seach__filters">
        {# filtros quedan estáticos como en el diseño #}
      </div>
    </div>
  </div>
</section>

<section class="du-generic-swiper du-swiper-program">
  <div class="du-generic-swiper__container du-swiper-program__container">

    <div class="du-generic-swiper__header">
      <h3>Mostrando <span>{{ docentes|length }} Docentes</span></h3>
    </div>

    <div class="swiper swiper-horizontal swiper-grid">

      <div class="swiper-wrapper" id="card__expert">

        {% for docente in docentes %}

        <div class="swiper-slide" data-nombre="{{ docente.nombre|lower }}">

          <article class="du-card__expert">

            <div class="du-card__expert-main">

              <img
                src="{{ docente.imagen }}"
                alt="{{ docente.nombre }}"
                class="du-card__expert-img"
              >

              <div class="du-card__expert-intro">
                <h3 class="du-card__expert-title">
                  {{ docente.nombre }}
                </h3>

                <p class="du-card__expert-role">
                  {{ docente.rol }}
                </p>
              </div>

            </div>

            <div class="du-card__expert-uni">
              <svg width="19" height="16" viewBox="0 0 19 16" fill="none">
                <path d="..." stroke="#007BE3"/>
              </svg>
              <span>{{ docente.universidad }}</span>
            </div>

            <div class="du-card__expert-uni">
              <svg width="15" height="13" viewBox="0 0 15 13" fill="none">
                <path d="..." stroke="#007BE3"></path>
              </svg>
              <span>Programas:</span>
            </div>

            <div class="du-card__expert-tags">

              {% for programa in docente.programas %}
                <span data-tag="{{ programa.tid }}">
                  {{ programa.tipo }}
                </span>
              {% endfor %}

            </div>

            <div class="du-card__expert-detail">
              <p>{{ docente.descripcion }}</p>
            </div>

            <div class="du-card__expert-footer">
              <a href="#" 
                 class="du-link-more du-open-modal"
                 data-target="modal-docente-{{ loop.index }}">
                 Ver detalle
              </a>
            </div>

          </article>

          <div id="modal-docente-{{ loop.index }}" class="du-modal">
            <div class="du-modal__overlay"></div>
            <div class="du-modal__container">
              <button class="du-modal__close">&times;</button>

              <div class="du-modal__content">
                <aside class="du-modal__aside">
                  <img src="{{ docente.imagen }}" alt="{{ docente.nombre }}" class="du-modal__img" />
                  <div class="du-modal__personal-info">
                    <h3 class="du-modal__name">{{ docente.nombre }}</h3>
                    <p class="du-modal__role">{{ docente.especialidad }}</p>

                    <div class="du-modal__contact">
                      <div class="du-modal__contact-item">
                        <svg width="14" height="18"><path d="..."/></svg>
                        <span>{{ docente.ciudad }}</span>
                      </div>

                      <div class="du-modal__contact-item">
                        <svg width="14" height="11"><path d="..."/></svg>
                        <a href="mailto:{{ docente.email }}">{{ docente.email }}</a>
                      </div>

                      <div class="du-modal__contact-item du-colum">
                        <div class="du-modal__contact-redes">
                          <a href="{{ docente.web }}" target="_blank"></a>
                        </div>
                        <a href="{{ docente.web }}" target="_blank" class="du-link-external">
                          {{ docente.web }}
                        </a>
                      </div>
                    </div>
                  </div>
                </aside>

                <main class="du-modal__main">

                  <section class="du-modal__section">
                    <h4 class="du-modal__section-title">Perfil profesional</h4>
                    <div class="du-modal__bio">{{ docente.perfil }}</div>
                  </section>

                  <section class="du-modal__section">
                    <h4 class="du-modal__section-title">Programas vinculados</h4>

                    <div class="du-modal__programs">

                      {% for programa in docente.programas %}
                        <div class="du-program-tag">

                          <span class="program-type" data-tag="{{ programa.tid }}">
                            {{ programa.tipo }}
                          </span>

                          <span class="program-name">
                            {{ programa.nombre }}
                          </span>

                        </div>
                      {% endfor %}

                    </div>

                  </section>

                </main>

              </div>
            </div>
          </div>

        </div>

        {% endfor %}

      </div>

    </div>

  </div>
</section>

<div id="container-modal"></div>
