<section class="du-seach">
  <div class="du-seach__container">
    <div class="du-seach__content">
      <div class="du-seach__input">
        <input type="text" id="buscar-docente" placeholder="Buscar docente...">
      </div>
      <div class="du-seach__filters">
        {# filtros quedan estáticos como en el diseño #}
      </div>
    </div>
  </div>
</section>

<section class="du-generic-swiper du-swiper-program">
  <div class="du-generic-swiper__container du-swiper-program__container">

    <div class="du-generic-swiper__header">
      <h3>Mostrando <span>{{ docentes|length }} Docentes</span></h3>
    </div>

    <div class="swiper swiper-horizontal swiper-grid"  id="docente-expert-swiper">

      <div class="swiper-wrapper" id="card__expert">

        {% for docente in docentes %}

        <div class="swiper-slide" data-nombre="{{ docente.nombre|lower }}">

          <article class="du-card__expert">

            <div class="du-card__expert-main">

              <img
                src="{{ docente.imagen }}"
                alt="{{ docente.nombre }}"
                class="du-card__expert-img"
              >

              <div class="du-card__expert-intro">
                <h3 class="du-card__expert-title">
                  {{ docente.nombre }}
                </h3>

                <p class="du-card__expert-role">
                  {{ docente.rol }}
                </p>
              </div>

            </div>

            <div class="du-card__expert-uni">

              <svg width="19" height="16" viewBox="0 0 19 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1.6682 5.45714V12.8569M0.909533 4.89437C0.371301 4.63655 0.371301 3.94098 0.909533 3.68316C1.61523 3.34511 2.6695 2.86529 4.16073 2.24411C6.23265 1.38107 7.64795 0.869318 8.40778 0.609939C8.83566 0.463354 9.30016 0.463354 9.72804 0.609939C10.4875 0.869318 11.9036 1.38107 13.9751 2.24411C15.4667 2.86529 16.5206 3.34511 17.2267 3.68316C17.7641 3.94098 17.7641 4.63655 17.2267 4.89437C16.5206 5.23242 15.4663 5.71223 13.9751 6.33342C11.9032 7.19646 10.4879 7.70821 9.72804 7.96759C9.30016 8.11417 8.83566 8.11417 8.40778 7.96759C7.64833 7.70821 6.23226 7.19646 4.16073 6.33342C2.66911 5.71185 1.61523 5.23242 0.909533 4.89437Z" stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4.04485 6.28516C4.01747 6.8093 4.00423 7.3341 4.00513 7.85896C4.00513 9.06394 4.06705 9.82066 4.12781 10.2736C4.18116 10.6693 4.40783 11.0058 4.76146 11.1908C5.44534 11.5491 6.83454 12.0784 9.06809 12.0784C11.3016 12.0784 12.6908 11.5495 13.3747 11.1912C13.7283 11.0062 13.955 10.6697 14.0084 10.2744C14.0691 9.82105 14.131 9.06433 14.131 7.85974C14.132 7.33474 14.1187 6.80982 14.0913 6.28555M2.83675 14.0256C2.83675 14.3355 2.71365 14.6327 2.49454 14.8518C2.27543 15.0709 1.97825 15.194 1.66838 15.194C1.3585 15.194 1.06132 15.0709 0.842209 14.8518C0.623096 14.6327 0.5 14.3355 0.5 14.0256C0.5 13.7158 0.623096 13.4186 0.842209 13.1995C1.06132 12.9804 1.3585 12.8573 1.66838 12.8573C1.97825 12.8573 2.27543 12.9804 2.49454 13.1995C2.71365 13.4186 2.83675 13.7158 2.83675 14.0256Z" stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>

              <span>
                {{ docente.universidad }}
              </span>

            </div>

            <div class="du-card__expert-uni">

              <svg width="15" height="13" viewBox="0 0 15 13" fill="none">
                <path d="M7.5 1.99463C7.5 1.99463 4 -1.00537 0.5 1.49463V12.4946C4 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463C7.5 1.99463 11 -1.00537 14.5 1.49463V12.4946C11 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463V12.4946"
                stroke="#007BE3"></path>
              </svg>

              <span>Programas:</span>

            </div>

            <div class="du-card__expert-tags">

              {% for programa in docente.programas %}
                <span data-tag="{{ programa.tid }}">{{ programa.tipo }}</span>
              {% endfor %}

            </div>

            <div class="du-card__expert-detail">
              <p>
                {{ docente.descripcion }}
              </p>
            </div>

            <div class="du-card__expert-footer">

              <a href="#" 
                 class="du-link-more du-open-modal"
                 data-target="modal-docente-{{ loop.index }}">
                 Ver detalle
              </a>

            </div>

          </article>

          <div id="modal-docente-{{ loop.index }}" class="du-modal">
            <div class="du-modal__overlay"></div>
            <div class="du-modal__container">
              <button class="du-modal__close">&times;</button>

              <div class="du-modal__content">
                <aside class="du-modal__aside">
                  <img
                    src="{{ docente.imagen }}"
                    alt="{{ docente.nombre }}"
                    class="du-modal__img"
                  />
                  <div class="du-modal__personal-info">
                    <h3 class="du-modal__name">
                      {{ docente.nombre }}
                    </h3>
                    <p class="du-modal__role">{{ docente.especialidad }}</p>

                    <div class="du-modal__contact">

                      <div class="du-modal__contact-item">
                        <svg width="14" height="18" viewBox="0 0 14 18" fill="none">
                          <path d="M7 9.4375C8.34619 9.4375 9.4375 8.34619 9.4375 7C9.4375 5.65381 8.34619 4.5625 7 4.5625C5.65381 4.5625 4.5625 5.65381 4.5625 7C4.5625 8.34619 5.65381 9.4375 7 9.4375Z" stroke="#007BE3"/>
                          <path d="M7 0.5C5.27609 0.5 3.62279 1.18482 2.40381 2.40381C1.18482 3.62279 0.5 5.27609 0.5 7C0.5 8.53725 0.826625 9.54312 1.71875 10.6562L7 16.75L12.2812 10.6562C13.1734 9.54312 13.5 8.53725 13.5 7C13.5 5.27609 12.8152 3.62279 11.5962 2.40381C10.3772 1.18482 8.72391 0.5 7 0.5Z" stroke="#007BE3"/>
                        </svg>
                        <span>{{ docente.ciudad }}</span>
                      </div>

                      <div class="du-modal__contact-item">
                        <svg width="14" height="11" viewBox="0 0 14 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M1.25689 11C0.898593 11 0.599667 10.879 0.360111 10.637C0.120556 10.395 0.000518519 10.0928 0 9.73028V1.26971C0 0.907762 0.120037 0.605785 0.360111 0.363786C0.600185 0.121786 0.898852 0.000523809 1.25611 0H12.7439C13.1017 0 13.4003 0.121262 13.6399 0.363786C13.8794 0.606309 13.9995 0.908286 14 1.26971V9.73107C14 10.0925 13.88 10.3945 13.6399 10.637C13.3998 10.8795 13.1011 11.0005 12.7439 11H1.25689ZM7 5.59114L0.777778 1.48107V9.73107C0.777778 9.87197 0.82263 9.98774 0.912333 10.0784C1.00204 10.169 1.11689 10.2143 1.25689 10.2143H12.7439C12.8834 10.2143 12.998 10.169 13.0877 10.0784C13.1774 9.98774 13.2222 9.87171 13.2222 9.73028V1.48029L7 5.59114ZM7 4.71428L12.9827 0.785714H1.01733L7 4.71428ZM0.777778 1.48107V0.785714V9.73107C0.777778 9.87197 0.82263 9.98774 0.912333 10.0784C1.00204 10.169 1.11689 10.2143 1.25689 10.2143H0.777778V1.48107Z" fill="#007BE3"/>
                        </svg>
                        <a href="mailto:{{ docente.email }}">
                          {{ docente.email }}
                        </a>
                      </div>

                      <div class="du-modal__contact-item du-colum">
                        <div class="du-modal__contact-redes">
                          <a href="{{ docente.web }}" target="_blank"></a>
                        </div>

                        <a href="{{ docente.web }}" target="_blank" class="du-link-external">
                          {{ docente.web }}
                        </a>
                      </div>

                    </div>
                  </div>
                </aside>

                <main class="du-modal__main">

                  <section class="du-modal__section">
                    <h4 class="du-modal__section-title">
                      <svg width="30" height="26" viewBox="0 0 30 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                          d="M2.47759 8.89237V21.42M1.19318 7.93961C0.281961 7.50313 0.281961 6.32553 1.19318 5.88904C2.38792 5.31673 4.17278 4.50441 6.69742 3.45275C10.2052 1.99163 12.6012 1.12525 13.8876 0.686125C14.612 0.437958 15.3984 0.437958 16.1228 0.686125C17.4085 1.12525 19.8059 1.99163 23.313 3.45275C25.8383 4.50441 27.6225 5.31673 28.8179 5.88904C29.7278 6.32553 29.7278 7.50313 28.8179 7.93961C27.6225 8.51193 25.8376 9.32425 23.313 10.3759C19.8053 11.837 17.4092 12.7034 16.1228 13.1425C15.3984 13.3907 14.612 13.3907 13.8876 13.1425C12.6019 12.7034 10.2045 11.837 6.69742 10.3759C4.17212 9.32359 2.38792 8.51193 1.19318 7.93961Z"
                          stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round" />
                        <path
                          d="M6.50139 10.2935C6.45504 11.1808 6.43261 12.0693 6.43413 12.9579C6.43413 14.9979 6.53897 16.279 6.64183 17.0458C6.73216 17.7157 7.1159 18.2854 7.71459 18.5986C8.87241 19.2052 11.2243 20.1013 15.0057 20.1013C18.787 20.1013 21.1389 19.2059 22.2967 18.5993C22.8954 18.2861 23.2792 17.7164 23.3695 17.0472C23.4724 16.2797 23.5772 14.9986 23.5772 12.9592C23.5787 12.0704 23.5563 11.1817 23.5099 10.2941M4.45609 23.398C4.45609 23.9226 4.24769 24.4257 3.87673 24.7967C3.50578 25.1676 3.00266 25.376 2.47804 25.376C1.95343 25.376 1.45031 25.1676 1.07936 24.7967C0.708401 24.4257 0.5 23.9226 0.5 23.398C0.5 22.8734 0.708401 22.3703 1.07936 21.9993C1.45031 21.6284 1.95343 21.42 2.47804 21.42C3.00266 21.42 3.50578 21.6284 3.87673 21.9993C4.24769 22.3703 4.45609 22.8734 4.45609 23.398Z"
                          stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      Perfil profesional
                    </h4>

                    <div class="du-modal__bio">
                      {{ docente.perfil }}
                    </div>

                  </section>

                  <section class="du-modal__section">

                    <h4 class="du-modal__section-title">
                      <svg width="26" height="20" viewBox="0 0 26 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                          d="M0 0.810818C0 0.595776 0.0856024 0.389541 0.237976 0.237483C0.390349 0.0854252 0.597012 1.26522e-07 0.8125 1.26522e-07H8.93425C10.6307 1.26522e-07 12.1247 0.864872 12.9978 2.17732C13.4425 1.50771 14.0465 0.958423 14.7558 0.578493C15.465 0.198563 16.2575 -0.000183062 17.0625 1.26522e-07H25.1875C25.403 1.26522e-07 25.6097 0.0854252 25.762 0.237483C25.9144 0.389541 26 0.595776 26 0.810818V17.0953C26 17.2022 25.9788 17.3081 25.9376 17.4068C25.8965 17.5056 25.8361 17.5952 25.7601 17.6705C25.6841 17.7459 25.5939 17.8055 25.4947 17.8459C25.3955 17.8864 25.2892 17.9068 25.1821 17.9061L16.8599 17.8499C16.4294 17.8468 16.0026 17.9292 15.6042 18.0921C15.2059 18.2551 14.8439 18.4954 14.5394 18.7991L13.5752 19.7623C13.4998 19.8377 13.4102 19.8975 13.3116 19.9382C13.213 19.979 13.1073 20 13.0005 20C12.8938 20 12.7881 19.979 12.6895 19.9382C12.5909 19.8975 12.5013 19.8377 12.4258 19.7623L11.4487 18.7883C10.8393 18.18 10.0128 17.8382 9.15092 17.838H0.8125C0.597012 17.838 0.390349 17.7526 0.237976 17.6005C0.0856024 17.4485 0 17.2422 0 17.0272L0 0.810818ZM13.8125 17.278C14.6825 16.591 15.7613 16.2207 16.8707 16.2282L24.375 16.2791V1.62164H17.0625C16.2005 1.62164 15.3739 1.96334 14.7644 2.57157C14.1549 3.1798 13.8125 4.00474 13.8125 4.86491V17.278ZM12.1842 4.86166C12.1834 4.00206 11.8406 3.17795 11.2312 2.57042C10.6218 1.96289 9.79564 1.62164 8.93425 1.62164H1.625V16.2164H9.15092C10.2537 16.2164 11.3241 16.5904 12.1875 17.2758L12.1842 4.86166Z"
                          fill="#007BE3" />
                      </svg>
                      Programas vinculados
                    </h4>

                    <div class="du-modal__programs">

                      {% for programa in docente.programas %}
                        <div class="du-program-tag">
                          <span class="program-type tag" data-tag="{{ programa.tid }}">
                            {{ programa.tipo }}
                          </span>
                          <span class="program-name">
                            {{ programa.nombre }}
                          </span>
                        </div>
                      {% endfor %}

                    </div>

                  </section>

                </main>

              </div>
            </div>
          </div>

        </div>

        {% endfor %}

      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>

    </div>

  </div>
</section>

<div id="container-modal"></div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const input = document.getElementById("buscar-docente");
  const cards = document.querySelectorAll("#card__expert .swiper-slide");

  input.addEventListener("keyup", function () {

    const filtro = this.value.toLowerCase();

    cards.forEach(function(card) {

      const nombre = card.getAttribute("data-nombre");

      if (nombre.includes(filtro)) {
        card.style.display = "block";
      } else {
        card.style.display = "none";
      }

    });

  });

});

document.addEventListener('click', function(e) {
  const link = e.target.closest('.du-open-modal');
  if (!link) return;

  e.preventDefault();
  const targetId = link.getAttribute('data-target');
  const modalContent = document.getElementById(targetId);

  if (modalContent) {

    const contenedor = document.getElementById('container-modal');

    contenedor.innerHTML = modalContent.outerHTML;

    const modal = contenedor.querySelector('.du-modal');

    modal.style.display = "flex";

    document.body.style.overflow = "hidden";

  }
});

document.addEventListener('click', function(e) {
  if (
    e.target.classList.contains('du-modal__close') ||
    e.target.classList.contains('du-modal__overlay')
  ) {

    const contenedor = document.getElementById('container-modal');

    document.body.style.overflow = "auto";

    contenedor.innerHTML = '';

  }
});
</script>
