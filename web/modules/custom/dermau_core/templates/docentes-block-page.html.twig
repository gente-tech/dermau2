<section class="du-seach">
  <div class="du-seach__container">
    <div class="du-seach__content">
      <div class="du-seach__input">
        <input type="text" id="buscar-docente" placeholder="Buscar docente...">
      </div>
      <div class="du-seach__filters">
        {# filtros quedan estáticos como en el diseño #}
      </div>
    </div>
  </div>
</section>

<section class="du-generic-swiper du-swiper-program">
  <div class="du-generic-swiper__container du-swiper-program__container">

    <div class="du-generic-swiper__header">
      <h3>Mostrando <span>{{ docentes|length }} Docentes</span></h3>
    </div>

    <div class="swiper swiper-horizontal swiper-grid">

      <div class="swiper-wrapper" id="card__expert">

        {% for docente in docentes %}

        <div class="swiper-slide" data-nombre="{{ docente.nombre|lower }}">

          <article class="du-card__expert">

            <div class="du-card__expert-main">

              <img
                src="{{ docente.imagen }}"
                alt="{{ docente.nombre }}"
                class="du-card__expert-img"
              >

              <div class="du-card__expert-intro">
                <h3 class="du-card__expert-title">
                  {{ docente.nombre }}
                </h3>

                <p class="du-card__expert-role">
                  {{ docente.rol }}
                </p>
              </div>

            </div>

            <div class="du-card__expert-uni">

              <svg width="21" height="21" viewBox="0 0 21 21" fill="none">
                <path d="M2.0432 7.26354V14.6632M1.28453 6.70077C0.746301 6.44295 0.746301 5.74737 1.28453 5.48955C1.99023 5.1515 3.0445 4.67169 4.53573 4.0505C6.60765 3.18746 8.02295 2.67571 8.78278 2.41634C9.21066 2.26975 9.67516 2.26975 10.103 2.41634C10.8625 2.67571 12.2786 3.18746 14.3501 4.0505C15.8417 4.67169 16.8956 5.1515 17.6017 5.48955C18.1391 5.74737 18.1391 6.44295 17.6017 6.70077C16.8956 7.03882 15.8413 7.51863 14.3501 8.13982C12.2782 9.00286 10.8629 9.51461 10.103 9.77399C9.67516 9.92057 9.21066 9.92057 8.78278 9.77399C8.02333 9.51461 6.60726 9.00286 4.53573 8.13982C3.04411 7.51824 1.99023 7.03882 1.28453 6.70077Z"
                stroke="#007BE3"></path>
              </svg>

              <span>
                {{ docente.universidad }}
              </span>

            </div>

            <div class="du-card__expert-uni">

              <svg width="15" height="13" viewBox="0 0 15 13" fill="none">
                <path d="M7.5 1.99463C7.5 1.99463 4 -1.00537 0.5 1.49463V12.4946C4 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463C7.5 1.99463 11 -1.00537 14.5 1.49463V12.4946C11 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463V12.4946"
                stroke="#007BE3"></path>
              </svg>

              <span>Programas:</span>

            </div>

            <div class="du-card__expert-tags">

              {% for programa in docente.programas %}
                <span>{{ programa }}</span>
              {% endfor %}

            </div>

            <div class="du-card__expert-detail">
              <p>
                {{ docente.descripcion }}
              </p>
            </div>

            <div class="du-card__expert-footer">

              <a href="#" 
                 class="du-link-more du-open-modal"
                 data-target="modal-docente-{{ loop.index }}">
                 Ver detalle
              </a>

            </div>

          </article>
          <div id="modal-docente-{{ loop.index }}" class="du-modal">
  <div class="du-modal__overlay"></div>
  <div class="du-modal__container">
    <button class="du-modal__close">&times;</button>

    <div class="du-modal__content">
      <aside class="du-modal__aside">
        <img
          src="{{ docente.imagen }}"
          alt="{{ docente.nombre }}"
          class="du-modal__img"
        />
        <div class="du-modal__personal-info">
          <h3 class="du-modal__name">
            {{ docente.nombre }}
          </h3>
          <p class="du-modal__role">{{ docente.especialidad }}</p>

          <div class="du-modal__contact">

            <div class="du-modal__contact-item">
              <svg width="14" height="18" viewBox="0 0 14 18" fill="none">
                <path d="M7 9.4375C8.34619 9.4375 9.4375 8.34619 9.4375 7C9.4375 5.65381 8.34619 4.5625 7 4.5625C5.65381 4.5625 4.5625 5.65381 4.5625 7C4.5625 8.34619 5.65381 9.4375 7 9.4375Z" stroke="#007BE3"/>
                <path d="M7 0.5C5.27609 0.5 3.62279 1.18482 2.40381 2.40381C1.18482 3.62279 0.5 5.27609 0.5 7C0.5 8.53725 0.826625 9.54312 1.71875 10.6562L7 16.75L12.2812 10.6562C13.1734 9.54312 13.5 8.53725 13.5 7C13.5 5.27609 12.8152 3.62279 11.5962 2.40381C10.3772 1.18482 8.72391 0.5 7 0.5Z" stroke="#007BE3"/>
              </svg>
              <span>{{ docente.ciudad }}</span>
            </div>

            <div class="du-modal__contact-item">
              <svg width="14" height="11" viewBox="0 0 14 11" fill="none">
                <path d="M1.25689 11C0.898593 11 0.599667 10.879 0.360111 10.637C0.120556 10.395 0.000518519 10.0928 0 9.73028V1.26971C0 0.907762 0.120037 0.605785 0.360111 0.363786C0.600185 0.121786 0.898852 0.000523809 1.25611 0H12.7439C13.1017 0 13.4003 0.121262 13.6399 0.363786C13.8794 0.606309 13.9995 0.908286 14 1.26971V9.73107C14 10.0925 13.88 10.3945 13.6399 10.637C13.3998 10.8795 13.1011 11.0005 12.7439 11H1.25689Z" fill="#007BE3"/>
              </svg>
              <a href="mailto:{{ docente.email }}">
                {{ docente.email }}
              </a>
            </div>

            <div class="du-modal__contact-item du-colum">
              <div class="du-modal__contact-redes">
                <a href="{{ docente.web }}" target="_blank"></a>
              </div>

              <a href="{{ docente.web }}" target="_blank" class="du-link-external">
                {{ docente.web }}
              </a>
            </div>

          </div>
        </div>
      </aside>

      <main class="du-modal__main">

        <section class="du-modal__section">
          <h4 class="du-modal__section-title">
            Perfil profesional
          </h4>

          <div class="du-modal__bio">
            {{ docente.perfil }}
          </div>

        </section>

        <section class="du-modal__section">

          <h4 class="du-modal__section-title">
            Programas vinculados
          </h4>

          <div class="du-modal__programs">

            {% for programa in docente.programas %}
              <div class="du-program-tag">
                <span class="program-name">
                  {{ programa }}
                </span>
              </div>
            {% endfor %}

          </div>

        </section>

      </main>

    </div>
  </div>
</div>

        </div>

        {% endfor %}

      </div>

      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>

    </div>

  </div>
</section>


<div id="container-modal"></div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const input = document.getElementById("buscar-docente");
  const cards = document.querySelectorAll("#card__expert .swiper-slide");

  input.addEventListener("keyup", function () {

    const filtro = this.value.toLowerCase();

    cards.forEach(function(card) {

      const nombre = card.getAttribute("data-nombre");

      if (nombre.includes(filtro)) {
        card.style.display = "block";
      } else {
        card.style.display = "none";
      }

    });

  });

});
</script>
<script>

document.addEventListener('click', function(e) {
  const link = e.target.closest('.du-open-modal');
  if (!link) return;

  e.preventDefault();
  const targetId = link.getAttribute('data-target');
  const modalContent = document.getElementById(targetId);

  if (modalContent) {
    const contenedor = document.getElementById('container-modal');
    contenedor.innerHTML = modalContent.outerHTML;;
    modalContent.style.display = "flex";
    document.body.style.overflow = "hidden";
  }
});

// Cerrar modal
document.addEventListener('click', function(e) {
  if (e.target.classList.contains('du-modal__close') ||   e.target.classList.contains('du-modal__overlay')) {
    const contenedor = document.getElementById('container-modal');
    //const modalContent = e.target.closest(".du-modal");
    //modalContent.style.display = "none";
    document.body.style.overflow = "auto";
    contenedor.innerHTML = '';
  }
});


</script>
