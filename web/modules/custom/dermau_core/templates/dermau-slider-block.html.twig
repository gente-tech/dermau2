<section class="du-hero-swiper">
	<div class="swiper">
		<div class="swiper-wrapper">

			{% for slide in sliders %}
				<div class="swiper-slide du-hero-swiper__slide">

					<div class="du-hero-swiper__bg" style="background-image: url('{{ slide.image.url }}');"></div>

					<div class="du-hero-swiper__overlay"></div>

					<div class="du-hero-swiper__container">
						<div class="du-hero-swiper__content">

							<h1 class="du-hero-swiper__title">
								{{ slide.titulo_blanco }}
								<span class="du-hero-swiper__title--highlight">
									{{ slide.titulo_azul }}
								</span>
							</h1>

							{% if slide.items_texto %}
								<ul class="du-hero-swiper__list">
									{% for item in slide.items_texto %}
										<li class="du-hero-swiper__item">
											{{ item }}
										</li>
									{% endfor %}
								</ul>
							{% endif %}

							<div class="du-hero-swiper__actions">

								{% if slide.url_cta %}
									<a href="{{ slide.url_cta }}" class="du-btn du-btn--primary">
										{{ slide.texto_cta }}
										<span class="du-icon__next"></span>
									</a>
								{% endif %}

							</div>

						</div>
					</div>
				</div>
			{% endfor %}

		</div>

		<div class="swiper-pagination"></div>
	</div>

	<div class="du-float-chat" data-float="true">
		<a href="#" class="du-float-chat__link">
			<img src="{{ base_path ~ directory }}/assets/img/humbleicons_chat.svg" alt="Chat" width="29" height="29">
		</a>
	</div>

	<div class="du-form-register" data-variation="" data-float="true">
		<div class="du-form-register__container">
			<h2 class="du-form-register__subtitle">
				Solicita más información
			</h2>
			{{ drupal_block('dermau_registro_form_block') }}
		</div>
	</div>

</section>
