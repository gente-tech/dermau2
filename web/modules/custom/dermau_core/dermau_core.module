use Drupal\node\Entity\Node;

function dermau_core_preprocess_node(&$variables)
{

  if (empty($variables['node'])) {
    return;
  }

  $node = $variables['node'];

  if ($node->bundle() !== 'programa') {
    return;
  }

  $query = \Drupal::entityQuery('node')
    ->condition('type', 'programa')
    ->condition('status', 1)
    ->condition('nid', $node->id(), '<>')
    ->range(0, 6)
    ->accessCheck(TRUE);

  $nids = $query->execute();

  $variables['otros_programas'] = !empty($nids)
    ? Node::loadMultiple($nids)
    : [];
}
