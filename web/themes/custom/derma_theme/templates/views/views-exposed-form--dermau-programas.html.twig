{{ attach_library('derma_theme/programas-filter') }}

<section class="du-seach">
	<div class="du-seach__container">
		<div class="du-seach__content">
			<form{{attributes}}>
				<div class="du-seach__input">
					{% if form.title.children.value is defined %}
						{{ form.title.children.value
              .setAttribute('placeholder', 'Buscar programa...')
              .setAttribute('id', 'program-search') }}
					{% elseif form.title.widget[0] is defined %}
						{{ form.title.widget[0]
              .setAttribute('placeholder', 'Buscar programa...')
              .setAttribute('id', 'program-search') }}
					{% else %}
						{{ form.title }}
					{% endif %}
				</div>

				{# filtros #}
				<div class="du-seach__filters">

					<div class="du-filter-native" style="display:none;">
						{% if form.field_universidad_del_programa_target_id_verf is defined %}
							{{ form.field_universidad_del_programa_target_id_verf }}
						{% endif %}

						{% if form.field_tipo_de_programa_target_id is defined %}
							{{ form.field_tipo_de_programa_target_id }}
						{% endif %}
					</div>
					<pre>{{ dump(form.field_universidad_del_programa_target_id_verf['#options']) }}</pre>
					<pre>{{ dump(form.field_tipo_de_programa_target_id['#options']) }}</pre>

					{% if form.field_universidad_del_programa_target_id_verf is defined %}
						{% set universidad_options = form.field_universidad_del_programa_target_id_verf['#options']|default([]) %}
						{% set universidad_default_value = '' %}
						{% set universidad_selected = form.field_universidad_del_programa_target_id_verf['#value']|default('') %}
						{% set universidad_label = 'Todas las universidades' %}

						{% for key, label in universidad_options %}
							{% if loop.first %}
								{% set universidad_default_value = key %}
							{% endif %}
							{% if key == universidad_selected and label != '- Any -' %}
								{% set universidad_label = label %}
							{% endif %}
						{% endfor %}

						{% if universidad_selected is empty %}
							{% set universidad_selected = universidad_default_value %}
						{% endif %}

						{% for key, label in universidad_options %}
							{% if key == universidad_selected and label != '- Any -' %}
								{% set universidad_label = label %}
							{% endif %}
						{% endfor %}

						<div class="du-filter-down" data-target="field_universidad_del_programa_target_id_verf">
							<div class="du-filter-down__header">
								<div class="du-filter-down__icon">
									<svg width="18" height="17" viewbox="0 0 18 17" fill="none">
										<path d="M1.625 0.75H15.625C15.8571 0.75 16.0796 0.842187 16.2437 1.00628C16.4078 1.17038 16.5 1.39294 16.5 1.625V3.01275C16.5 3.2448 16.4077 3.46732 16.2436 3.63137L10.6314 9.24362C10.4673 9.40768 10.375 9.6302 10.375 9.86225V15.3791" stroke="#007BE3"/>
									</svg>
								</div>
								<div class="du-filter-down__title" id="filter-universidad" data-value="{{ universidad_selected }}">
									{{ universidad_label }}
								</div>
							</div>

							<ul class="du-filter-down__options" data-rel="filter-universidad">
								<li data-value="{{ universidad_default_value }}">Todas las universidades</li>
								{% for key, label in universidad_options %}
									{% if label != '- Any -' %}
										<li data-value="{{ key }}">
											{{ label }}
										</li>
									{% endif %}
								{% endfor %}
							</ul>
						</div>
					{% endif %}

					{% if form.field_tipo_de_programa_target_id is defined %}
						{% set tipo_options = form.field_tipo_de_programa_target_id['#options']|default([]) %}
						{% set tipo_default_value = '' %}
						{% set tipo_selected = form.field_tipo_de_programa_target_id['#value']|default('') %}
						{% set tipo_label = 'Todos los programas' %}

						{% for key, label in tipo_options %}
							{% if loop.first %}
								{% set tipo_default_value = key %}
							{% endif %}
							{% if key == tipo_selected and label != '- Any -' %}
								{% set tipo_label = label %}
							{% endif %}
						{% endfor %}

						{% if tipo_selected is empty %}
							{% set tipo_selected = tipo_default_value %}
						{% endif %}

						{% for key, label in tipo_options %}
							{% if key == tipo_selected and label != '- Any -' %}
								{% set tipo_label = label %}
							{% endif %}
						{% endfor %}

						<div class="du-filter-down" data-target="field_tipo_de_programa_target_id">
							<div class="du-filter-down__header">
								<div class="du-filter-down__icon">
									<svg width="21" height="17" viewbox="0 0 21 17" fill="none">
										<path d="M0 0.65625C0 0.482202 0.0691404 0.315282 0.192211 0.192211C0.315282 0.0691405 0.482202 0 0.65625 0H7.21612" fill="#007BE3"/>
									</svg>
								</div>
								<div class="du-filter-down__title" id="filter-programa" data-value="{{ tipo_selected }}">
									{{ tipo_label }}
								</div>
							</div>

							<ul class="du-filter-down__options" data-rel="filter-programa">
								<li data-value="{{ tipo_default_value }}">Todos los programas</li>
								{% for key, label in tipo_options %}
									{% if label != '- Any -' %}
										<li data-value="{{ key }}">
											{{ label }}
										</li>
									{% endif %}
								{% endfor %}
							</ul>
						</div>
					{% endif %}

				</div>

				<div style="display:none;">
					{{ form.actions }}
				</div>

				{{ form.form_build_id }}
				{{ form.form_token }}
				{{ form.form_id }}
			</form>
		</div>
	</div>
</section>
