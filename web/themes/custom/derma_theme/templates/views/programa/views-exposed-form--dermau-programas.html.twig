{{ attach_library('derma_theme/programas-filter') }}

<section class="du-seach">
	<div class="du-seach__container">
		<div class="du-seach__content">
			<form{{attributes}}>
				<div class="du-seach__input">
					{% if form.title.children.value is defined %}
						{{ form.title.children.value
              .setAttribute('placeholder', 'Buscar programa...')
              .setAttribute('id', 'program-search') }}
					{% elseif form.title.widget[0] is defined %}
						{{ form.title.widget[0]
              .setAttribute('placeholder', 'Buscar programa...')
              .setAttribute('id', 'program-search') }}
					{% else %}
						{{ form.title }}
					{% endif %}
				</div>

				{# filtros #}
				<div class="du-seach__filters">

					<div class="du-filter-native" style="display:none;">
						{% if form.field_universidad_del_programa_target_id_verf is defined %}
							{{ form.field_universidad_del_programa_target_id_verf }}
						{% endif %}

						{% if form.field_tipo_de_programa_target_id is defined %}
							{{ form.field_tipo_de_programa_target_id }}
						{% endif %}
					</div>

					{% if form.field_universidad_del_programa_target_id_verf is defined %}
						{% set universidad_options = form.field_universidad_del_programa_target_id_verf['#options']|default([]) %}
						{% set universidad_default_value = '' %}
						{% set universidad_selected = form.field_universidad_del_programa_target_id_verf['#value']|default('') %}
						{% set universidad_label = 'Todas las universidades' %}

						{% for key, label in universidad_options %}
							{% if loop.first %}
								{% set universidad_default_value = key %}
							{% endif %}
							{% if key == universidad_selected and label != '- Any -' %}
								{% set universidad_label = label %}
							{% endif %}
						{% endfor %}

						{% if universidad_selected is empty %}
							{% set universidad_selected = universidad_default_value %}
						{% endif %}

						{% for key, label in universidad_options %}
							{% if key == universidad_selected and label != '- Any -' %}
								{% set universidad_label = label %}
							{% endif %}
						{% endfor %}

						<div class="du-filter-down" data-target="field_universidad_del_programa_target_id_verf">
							<div class="du-filter-down__header">
								<div class="du-filter-down__icon">
									<svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M1.625 0.75H15.625C15.8571 0.75 16.0796 0.842187 16.2437 1.00628C16.4078 1.17038 16.5 1.39294 16.5 1.625V3.01275C16.5 3.2448 16.4077 3.46732 16.2436 3.63137L10.6314 9.24362C10.4673 9.40768 10.375 9.6302 10.375 9.86225V15.3791C10.375 15.5121 10.3447 15.6434 10.2863 15.7629C10.228 15.8824 10.1432 15.9871 10.0383 16.0689C9.93346 16.1507 9.81133 16.2076 9.6812 16.2351C9.55108 16.2627 9.41639 16.2602 9.28737 16.2279L7.53737 15.7904C7.34816 15.743 7.18021 15.6337 7.0602 15.4799C6.94019 15.3262 6.87501 15.1367 6.875 14.9416V9.86225C6.87495 9.6302 6.78273 9.40768 6.61862 9.24362L1.00637 3.63137C0.842269 3.46732 0.75005 3.2448 0.75 3.01275V1.625C0.75 1.39294 0.842187 1.17038 1.00628 1.00628C1.17038 0.842187 1.39294 0.75 1.625 0.75Z" stroke="#007BE3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
								</div>
								<div class="du-filter-down__title" id="filter-universidad" data-value="{{ universidad_selected }}">
									{{ universidad_label }}
								</div>
							</div>

							<ul class="du-filter-down__options" data-rel="filter-universidad">
								<li data-value="{{ universidad_default_value }}">Todas las universidades</li>
								{% for key, label in universidad_options %}
									{% if label != '- Any -' %}
										<li data-value="{{ key }}">
											{{ label }}
										</li>
									{% endif %}
								{% endfor %}
							</ul>
						</div>
					{% endif %}

					{% if form.field_tipo_de_programa_target_id is defined %}
						{% set tipo_options = form.field_tipo_de_programa_target_id['#options']|default([]) %}
						{% set tipo_default_value = '' %}
						{% set tipo_selected = form.field_tipo_de_programa_target_id['#value']|default('') %}
						{% set tipo_label = 'Todos los programas' %}

						{% for key, label in tipo_options %}
							{% if loop.first %}
								{% set tipo_default_value = key %}
							{% endif %}
							{% if key == tipo_selected and label != '- Any -' %}
								{% set tipo_label = label %}
							{% endif %}
						{% endfor %}

						{% if tipo_selected is empty %}
							{% set tipo_selected = tipo_default_value %}
						{% endif %}

						{% for key, label in tipo_options %}
							{% if key == tipo_selected and label != '- Any -' %}
								{% set tipo_label = label %}
							{% endif %}
						{% endfor %}

						<div class="du-filter-down" data-target="field_tipo_de_programa_target_id">
							<div class="du-filter-down__header">
								<div class="du-filter-down__icon">
									<svg width="21" height="17" viewBox="0 0 21 17" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M0 0.65625C0 0.482202 0.0691404 0.315282 0.192211 0.192211C0.315282 0.0691405 0.482202 1.02403e-07 0.65625 1.02403e-07H7.21612C8.58637 1.02403e-07 9.793 0.7 10.4982 1.76225C10.8574 1.22029 11.3452 0.775717 11.9181 0.468213C12.491 0.16071 13.1311 -0.000148165 13.7812 1.02403e-07H20.3438C20.5178 1.02403e-07 20.6847 0.0691405 20.8078 0.192211C20.9309 0.315282 21 0.482202 21 0.65625V13.8364C21 13.9229 20.9829 14.0086 20.9496 14.0885C20.9164 14.1684 20.8676 14.241 20.8062 14.302C20.7448 14.363 20.672 14.4112 20.5919 14.4439C20.5117 14.4767 20.4259 14.4932 20.3394 14.4926L13.6176 14.4471C13.2699 14.4447 12.9252 14.5113 12.6034 14.6432C12.2817 14.7751 11.9893 14.9696 11.7434 15.2154L10.9646 15.995C10.9037 16.056 10.8313 16.1044 10.7517 16.1374C10.672 16.1704 10.5867 16.1874 10.5004 16.1874C10.4142 16.1874 10.3289 16.1704 10.2492 16.1374C10.1696 16.1044 10.0972 16.056 10.0362 15.995L9.247 15.2066C8.75483 14.7143 8.08726 14.4377 7.39112 14.4375H0.65625C0.482202 14.4375 0.315282 14.3684 0.192211 14.2453C0.0691404 14.1222 0 13.9553 0 13.7813L0 0.65625ZM11.1562 13.9843C11.859 13.4282 12.7303 13.1285 13.6264 13.1346L19.6875 13.1758V1.3125H13.7812C13.0851 1.3125 12.4174 1.58906 11.9251 2.08135C11.4328 2.57363 11.1562 3.24131 11.1562 3.9375V13.9843ZM9.84112 3.93488C9.84043 3.23914 9.56356 2.57213 9.07135 2.08042C8.57914 1.5887 7.91186 1.3125 7.21612 1.3125H1.3125V13.125H7.39112C8.28187 13.125 9.14637 13.4278 9.84375 13.9825L9.84112 3.93488Z" fill="#007BE3"/>
									</svg>
								</div>
								<div class="du-filter-down__title" id="filter-programa" data-value="{{ tipo_selected }}">
									{{ tipo_label }}
								</div>
							</div>

							<ul class="du-filter-down__options" data-rel="filter-programa">
								<li data-value="{{ tipo_default_value }}">Todos los programas</li>
								{% for key, label in tipo_options %}
									{% if label != '- Any -' %}
										<li data-value="{{ key }}">
											{{ label }}
										</li>
									{% endif %}
								{% endfor %}
							</ul>
						</div>
					{% endif %}

				</div>

				<div style="display:none;">
					{{ form.actions }}
				</div>

				{{ form.form_build_id }}
				{{ form.form_token }}
				{{ form.form_id }}
			</form>
		</div>
	</div>
</section>
