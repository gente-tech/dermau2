{%
  set classes = [
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{attributes.addClass(classes)}}>
	{{ title_prefix }}
	{% if title %}
		{{ title }}
	{% endif %}
	{{ title_suffix }}

	{% if header %}
		{{ header }}
	{% endif %}

	{% if exposed %}
		{{ exposed }}
	{% endif %}

	{% if attachment_before %}
		{{ attachment_before }}
	{% endif %}

	{% if rows %}
		{{ rows }}
	{% elseif empty %}
		{{ empty }}
	{% endif %}

	{% if pager %}
		<div class="du-pagination">
			{{ pager }}
		</div>
	{% endif %}

	{% if attachment_after %}
		{{ attachment_after }}
	{% endif %}

	{% if more %}
		{{ more }}
	{% endif %}

	{% if footer %}
		{{ footer }}
	{% endif %}

	{% if feed_icons %}
		{{ feed_icons }}
	{% endif %}
</div>
