          ></div>
          <div class="du-hero__overlay"></div>
          <div class="du-hero__wrapper">
            <div class="du-hero__content">
              <h1 class="du-hero__title">
                {{ node.label }}
              </h1>
              <div class="du-hero__text">
                <p>
                  {{ node.field_descripcion_corta.value }}
                </p>
                <p>
                  {{ node.field_descripcion_general.value }}
                </p>
              </div>
              <div class="du-hero__actions">
                <a href="#" class="du-btn du-btn--primary"
                  >Ver programas <span class="du-icon__next"></span
                ></a>
                <a href="#" class="du-btn du-btn--secundary-dark"
                  >Conoce los convenios</a
                >
              </div>
            </div>
          </div>
        </div>

